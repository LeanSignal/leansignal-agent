<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.leansignal.victoria-metrics</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/victoria-metrics</string>
        <string>--storageDataPath=/usr/local/var/leansignal-agent/vm</string>
        <string>--retentionPeriod=1d</string>
        <string>--httpListenAddr=127.0.0.1:8428</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/usr/local/var/log/leansignal-agent/victoria-metrics.log</string>
    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/leansignal-agent/victoria-metrics.log</string>
</dict>
</plist>
